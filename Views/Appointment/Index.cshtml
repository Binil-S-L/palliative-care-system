@model IEnumerable<PalliativeCare.Models.Appointment>
@{ ViewData["Title"] = "Appointments"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <div><h5 class="mb-0 fw-bold">Appointments</h5><small class="text-muted">@Model.Count() results</small></div>
    <div class="d-flex gap-2">
        <a asp-action="Today" class="btn btn-outline-primary"><i class="fas fa-calendar-day me-1"></i>Today</a>
        <a asp-action="Create" class="btn btn-primary"><i class="fas fa-calendar-plus me-1"></i>Schedule</a>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-semibold">From</label>
                <input type="date" name="from" value="@ViewBag.From" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">To</label>
                <input type="date" name="to" value="@ViewBag.To" class="form-control" />
            </div>
            <div class="col-md-2"><button type="submit" class="btn btn-primary w-100 mt-3">Filter</button></div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-calendar-times fa-3x mb-3 d-block opacity-25"></i>
                <p>No appointments in this range.</p>
                <a asp-action="Create" class="btn btn-primary">Schedule First Appointment</a>
            </div>
        }
        else
        {
            <table class="table table-hover align-middle mb-0">
                <thead><tr><th>Date & Time</th><th>Patient</th><th>Doctor</th><th>Purpose</th><th>Type</th><th>Duration</th><th>Status</th><th></th></tr></thead>
                <tbody>
                @foreach (var a in Model)
                {
                    var isToday = a.ScheduledAt.Date == DateTime.Today;
                    <tr class="@(isToday ? "table-info" : "")">
                        <td>
                            <div class="fw-semibold">@a.ScheduledAt.ToString("dd MMM yyyy")</div>
                            <div class="text-muted small">@a.ScheduledAt.ToString("HH:mm") @(isToday ? "· Today" : "")</div>
                        </td>
                        <td><a asp-controller="Patient" asp-action="Details" asp-route-id="@a.PatientId" class="text-decoration-none fw-semibold">@a.Patient?.FullName</a></td>
                        <td class="text-muted small">@a.Doctor?.FullName</td>
                        <td>@a.Purpose</td>
                        <td><span class="badge bg-info bg-opacity-15 text-info">@a.Type</span></td>
                        <td class="text-muted small">@a.DurationMinutes min</td>
                        <td>
                            @{
                                var sc = a.Status switch {
                                    PalliativeCare.Models.AppointmentStatus.Scheduled => "warning",
                                    PalliativeCare.Models.AppointmentStatus.Confirmed => "success",
                                    PalliativeCare.Models.AppointmentStatus.Completed => "secondary",
                                    PalliativeCare.Models.AppointmentStatus.Cancelled => "danger",
                                    _ => "dark"
                                };
                            }
                            <span class="badge bg-@sc bg-opacity-15 text-dark">@a.Status</span>
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Edit" asp-route-id="@a.Id" class="btn btn-sm btn-outline-secondary"><i class="fas fa-edit"></i></a>
                                <form asp-action="Delete" asp-route-id="@a.Id" method="post" onsubmit="return confirm('Cancel this appointment?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-times"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</div>
