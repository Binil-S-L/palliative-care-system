@model PalliativeCare.Models.Doctor
@{ ViewData["Title"] = Model.Id == 0 ? "Add Staff Member" : "Edit Staff Member"; var isEdit = Model.Id != 0; }

<div class="d-flex align-items-center gap-2 mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="fas fa-arrow-left"></i></a>
    <h5 class="mb-0 fw-bold">@ViewData["Title"]</h5>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
            @Html.AntiForgeryToken()
            @if (isEdit) { <input type="hidden" asp-for="Id" /> }
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="card">
                <div class="card-header"><i class="fas fa-user-md me-2 text-primary"></i>Staff Details</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label fw-semibold small"></label>
                            <input asp-for="FirstName" class="form-control" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label fw-semibold small"></label>
                            <input asp-for="LastName" class="form-control" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Specialisation" class="form-label fw-semibold small"></label>
                            <input asp-for="Specialisation" class="form-control" placeholder="e.g. Palliative Medicine, Pain Management" />
                            <span asp-validation-for="Specialisation" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Role" class="form-label fw-semibold small"></label>
                            <select asp-for="Role" class="form-select" asp-items="Html.GetEnumSelectList<PalliativeCare.Models.DoctorRole>()"></select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label fw-semibold small"></label>
                            <input asp-for="Phone" class="form-control" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-semibold small"></label>
                            <input asp-for="Email" class="form-control" type="email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LicenceNumber" class="form-label fw-semibold small">Licence / GMC Number</label>
                            <input asp-for="LicenceNumber" class="form-control" placeholder="Optional" />
                        </div>
                        <div class="col-md-6 d-flex align-items-end pb-1">
                            <div class="form-check form-switch">
                                <input asp-for="IsAvailable" class="form-check-input" type="checkbox" />
                                <label asp-for="IsAvailable" class="form-check-label fw-semibold small">Currently Available</label>
                            </div>
                        </div>
                        <div class="col-12 d-flex gap-2 justify-content-end">
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>@(isEdit ? "Save Changes" : "Add Staff Member")</button>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
