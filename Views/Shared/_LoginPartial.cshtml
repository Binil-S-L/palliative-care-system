@using Microsoft.AspNetCore.Identity
@inject SignInManager<PalliativeCare.Data.ApplicationUser> SignInManager
@inject UserManager<PalliativeCare.Data.ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
        <span class="text-muted small me-2">@UserManager.GetUserName(User)</span>
        <button type="submit" class="btn btn-sm btn-outline-secondary">Logout</button>
    </form>
}
else
{
    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-sm btn-outline-primary">Login</a>
}
