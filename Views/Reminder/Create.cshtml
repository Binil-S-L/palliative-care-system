@model PalliativeCare.Models.Reminder
@{ ViewData["Title"] = "New Reminder"; }

<div class="d-flex align-items-center gap-2 mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="fas fa-arrow-left"></i></a>
    <h5 class="mb-0 fw-bold">New Reminder</h5>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="card">
                <div class="card-header"><i class="fas fa-bell me-2 text-danger"></i>Reminder Details</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Title" class="form-label fw-semibold small"></label>
                            <input asp-for="Title" class="form-control" placeholder="e.g. Medication review, Follow-up call..." />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PatientId" class="form-label fw-semibold small">Patient (optional)</label>
                            <select asp-for="PatientId" class="form-select" asp-items="ViewBag.Patients"><option value="">— General —</option></select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DoctorId" class="form-label fw-semibold small">Assign To (optional)</label>
                            <select asp-for="DoctorId" class="form-select" asp-items="ViewBag.Doctors"><option value="">— Anyone —</option></select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Type" class="form-label fw-semibold small">Type</label>
                            <select asp-for="Type" class="form-select" asp-items="Html.GetEnumSelectList<PalliativeCare.Models.ReminderType>()"></select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DueAt" class="form-label fw-semibold small">Due At</label>
                            <input asp-for="DueAt" class="form-control" type="datetime-local" />
                            <span asp-validation-for="DueAt" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Message" class="form-label fw-semibold small">Message (optional)</label>
                            <textarea asp-for="Message" class="form-control" rows="3" placeholder="Additional details..."></textarea>
                        </div>
                        <div class="col-12 d-flex gap-2 justify-content-end">
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-danger"><i class="fas fa-bell me-2"></i>Create Reminder</button>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
