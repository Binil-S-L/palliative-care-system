@model IEnumerable<PalliativeCare.Models.Reminder>
@{ ViewData["Title"] = "Reminders"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <div><h5 class="mb-0 fw-bold">Reminders & Alerts</h5></div>
    <a asp-action="Create" class="btn btn-outline-danger"><i class="fas fa-bell me-2"></i>New Reminder</a>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-bell-slash fa-3x mb-3 d-block opacity-25"></i>No reminders.
            </div>
        }
        else
        {
            <table class="table table-hover align-middle mb-0">
                <thead><tr><th>Title</th><th>Patient</th><th>Type</th><th>Due</th><th>Status</th><th></th></tr></thead>
                <tbody>
                @foreach (var r in Model)
                {
                    var isOverdue = r.DueAt < DateTime.Now && r.Status == PalliativeCare.Models.ReminderStatus.Pending;
                    <tr class="@(isOverdue ? "table-danger" : "")">
                        <td class="fw-semibold">@r.Title</td>
                        <td>
                            @if (r.Patient != null)
                            { <a asp-controller="Patient" asp-action="Details" asp-route-id="@r.PatientId" class="text-decoration-none">@r.Patient.FullName</a> }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td><span class="badge bg-primary bg-opacity-10 text-primary">@r.Type</span></td>
                        <td>
                            @r.DueAt.ToString("dd MMM yyyy HH:mm")
                            @if (isOverdue) { <span class="badge bg-danger ms-1" style="font-size:0.65rem">Overdue</span> }
                        </td>
                        <td><span class="badge bg-@(r.Status == PalliativeCare.Models.ReminderStatus.Pending ? "warning" : r.Status == PalliativeCare.Models.ReminderStatus.Sent ? "success" : "secondary") bg-opacity-15 text-dark">@r.Status</span></td>
                        <td>
                            @if (r.Status == PalliativeCare.Models.ReminderStatus.Pending)
                            {
                                <div class="d-flex gap-1">
                                    <form asp-action="MarkSent" asp-route-id="@r.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-success" title="Mark Sent"><i class="fas fa-check"></i></button>
                                    </form>
                                    <form asp-action="Dismiss" asp-route-id="@r.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-secondary" title="Dismiss"><i class="fas fa-times"></i></button>
                                    </form>
                                </div>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</div>
