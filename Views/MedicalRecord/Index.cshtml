@model IEnumerable<PalliativeCare.Models.MedicalRecord>
@{ ViewData["Title"] = "Medical Records"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <div><h5 class="mb-0 fw-bold">Medical Records</h5></div>
    <a asp-action="Create" class="btn btn-success"><i class="fas fa-notes-medical me-2"></i>New Record</a>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-file-medical fa-3x mb-3 d-block opacity-25"></i>No medical records found.
            </div>
        }
        else
        {
            <table class="table table-hover align-middle mb-0">
                <thead><tr><th>Date</th><th>Patient</th><th>Type</th><th>Chief Complaint</th><th>Doctor</th><th>Pain Score</th><th></th></tr></thead>
                <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>@r.RecordDate.ToString("dd MMM yyyy")<div class="text-muted small">@r.RecordDate.ToString("HH:mm")</div></td>
                        <td><a asp-controller="Patient" asp-action="Details" asp-route-id="@r.PatientId" class="fw-semibold text-decoration-none">@r.Patient?.FullName</a></td>
                        <td><span class="badge bg-primary bg-opacity-10 text-primary">@r.Type</span></td>
                        <td>@r.ChiefComplaint</td>
                        <td class="text-muted small">@r.Doctor?.FullName</td>
                        <td>
                            @if (r.PainScore != null)
                            {
                                var score = int.TryParse(r.PainScore, out var s) ? s : 0;
                                var col = score >= 7 ? "danger" : score >= 4 ? "warning" : "success";
                                <span class="badge bg-@col bg-opacity-15 text-@col fw-bold">@r.PainScore/10</span>
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td><a asp-action="Details" asp-route-id="@r.Id" class="btn btn-sm btn-outline-secondary"><i class="fas fa-eye"></i></a></td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</div>
