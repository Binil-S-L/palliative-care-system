@model IEnumerable<PalliativeCare.Models.Patient>
@{ ViewData["Title"] = "Patients"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h5 class="mb-0 fw-bold">All Patients</h5>
        <small class="text-muted">@Model.Count() records</small>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-user-plus me-2"></i>Register Patient
    </a>
</div>

<!-- Search & Filter -->
<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label small fw-semibold">Search</label>
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control border-start-0" placeholder="Name, phone, diagnosis..." />
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Status</label>
                <select name="status" class="form-select">
                    <option value="">All Statuses</option>
                    @foreach (var s in Enum.GetValues<PalliativeCare.Models.PatientStatus>())
                    {
                        <option value="@s" selected="@(ViewBag.Status?.ToString() == s.ToString())">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Filter</button>
            </div>
            <div class="col-md-2">
                <a asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-user-injured fa-3x mb-3 d-block opacity-25"></i>
                <p>No patients found.</p>
                <a asp-action="Create" class="btn btn-primary">Register First Patient</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Patient</th>
                            <th>Age / Gender</th>
                            <th>Contact</th>
                            <th>Diagnosis</th>
                            <th>Assigned Doctor</th>
                            <th>Status</th>
                            <th>Registered</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var p in Model)
                    {
                        var statusClass = p.Status switch {
                            PalliativeCare.Models.PatientStatus.Active     => "badge-active",
                            PalliativeCare.Models.PatientStatus.Inactive   => "badge-inactive",
                            PalliativeCare.Models.PatientStatus.Discharged => "badge-discharged",
                            PalliativeCare.Models.PatientStatus.Deceased   => "badge-deceased",
                            _ => "bg-secondary"
                        };
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-bold" style="width:36px;height:36px;font-size:0.85rem">
                                        @p.FirstName[0]@p.LastName[0]
                                    </div>
                                    <div>
                                        <a asp-action="Details" asp-route-id="@p.Id" class="fw-semibold text-decoration-none text-dark">@p.FullName</a>
                                        <div class="text-muted" style="font-size:0.78rem">ID: #@p.Id</div>
                                    </div>
                                </div>
                            </td>
                            <td>@p.Age yrs / @p.Gender</td>
                            <td>
                                <div>@p.Phone</div>
                                @if (p.Email != null) { <div class="text-muted small">@p.Email</div> }
                            </td>
                            <td class="text-muted small">@p.Diagnosis</td>
                            <td class="text-muted small">@(p.Doctor?.FullName ?? "—")</td>
                            <td><span class="badge @statusClass px-2 py-1">@p.Status</span></td>
                            <td class="text-muted small">@p.RegisteredAt.ToString("dd MMM yyyy")</td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary" title="View"><i class="fas fa-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary" title="Edit"><i class="fas fa-edit"></i></a>
                                    <a asp-controller="Appointment" asp-action="Create" asp-route-patientId="@p.Id" class="btn btn-sm btn-outline-success" title="Schedule"><i class="fas fa-calendar-plus"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
